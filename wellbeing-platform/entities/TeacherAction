{
  "name": "TeacherAction",
  "type": "object",
  "properties": {
    "student_id": {
      "type": "string",
      "description": "Reference to student profile"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "open_survey",
        "monitor",
        "check_in",
        "refer_counsellor",
        "parent_contact"
      ],
      "description": "Type of action taken"
    },
    "notes": {
      "type": "string",
      "description": "Teacher's notes about the interaction"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "improved",
        "same",
        "worse",
        "pending"
      ],
      "default": "pending",
      "description": "Outcome after action"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the action has been completed"
    },
    "referral_summary": {
      "type": "string",
      "description": "Auto-generated summary for referral"
    },
    "follow_up_due_at": {
      "type": "string",
      "description": "ISO timestamp for the next suggested follow-up"
    },
    "generated_parent_message": {
      "type": "string",
      "description": "Editable parent communication drafted by the system"
    },
    "escalation_payload": {
      "type": "object",
      "description": "Structured escalation package containing key signals, trends, and notes"
    },
    "teacher_email": {
      "type": "string",
      "description": "Teacher who took the action"
    }
  },
  "required": [
    "student_id",
    "action_type"
  ]
}
